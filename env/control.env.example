VN_NEWS_RELEASE_TAG=replace-with-release-tag
VN_NEWS_IMAGE_REGISTRY=replace-with-image-registry
VN_NEWS_IMAGE_NAMESPACE=replace-with-image-namespace
VN_NEWS_CONFIG_HOST_DIR=/srv/vn-news-config/configs
VN_NEWS_ADMIN_BIND_ADDRESS=127.0.0.1
VN_NEWS_APP_BIND_ADDRESS=127.0.0.1
VN_NEWS_CLOUDFLARED_IMAGE=cloudflare/cloudflared:2026.5.2
VN_NEWS_DOCKER_DAEMON_URL=tcp://docker-socket-proxy:2375
VN_NEWS_RECOVERY_BUCKET=tgb-vn-news-recovery
VN_NEWS_ORCHESTRATION_GIT_URL=https://github.com/ToGiaBaoKDL/vn-news-orchestration.git
VN_NEWS_ORCHESTRATION_GIT_REF=main
VN_NEWS_REDPANDA_BOOTSTRAP_SERVERS=10.0.10.16:19092
VN_NEWS_SCHEMA_REGISTRY_URL=http://10.0.10.16:18081
VN_NEWS_STORAGE_ENDPOINT_URL=http://10.0.10.16:8333
VN_NEWS_API_BASE_URL=http://api:8000
VN_NEWS_SECRETS_HOST_DIR=/run/vn-news/secrets
VN_NEWS_HOST_SECRET_GROUP=vn-news
VN_NEWS_APP_UID=10001
VN_NEWS_AIRFLOW_UID=50000
VN_NEWS_AIRFLOW_GID=0
VN_NEWS_STORAGE_ADMIN_S3_CREDENTIALS_SECRET_OCID=ocid1.vaultsecret.replace-with-storage-admin-s3-credentials-secret-ocid
VN_NEWS_INGESTION_S3_CREDENTIALS_SECRET_OCID=ocid1.vaultsecret.replace-with-ingestion-s3-credentials-secret-ocid
VN_NEWS_AIRFLOW_DB_PASSWORD_SECRET_OCID=ocid1.vaultsecret.replace-with-airflow-db-password-secret-ocid
VN_NEWS_AIRFLOW_API_JWT_SECRET_OCID=ocid1.vaultsecret.replace-with-airflow-api-jwt-secret-ocid
VN_NEWS_AIRFLOW_FERNET_KEY_SECRET_OCID=ocid1.vaultsecret.replace-with-airflow-fernet-key-secret-ocid
VN_NEWS_AIRFLOW_ADMIN_PASSWORD_SECRET_OCID=ocid1.vaultsecret.replace-with-airflow-admin-password-secret-ocid
VN_NEWS_CLOUDFLARE_CONTROL_TUNNEL_TOKEN_SECRET_OCID=ocid1.vaultsecret.replace-with-cloudflare-control-tunnel-token-secret-ocid
VN_NEWS_AIRFLOW_ADMIN_USERNAME=tgb_admin
VN_NEWS_AIRFLOW_ADMIN_EMAIL=admin@vn-news.local
